<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio Manager</title>
    <style>
        body { background-color: #000; color: #fff; font-family: sans-serif; margin: 0; padding: 15px; font-weight: 500; }
        h1, h2, h3, th { color: #00d4ff; font-weight: 800; }
        .container { max-width: 600px; margin: auto; }
        .summary-box { background: #111; padding: 15px; border-radius: 10px; margin-bottom: 15px; border: 2px solid #007bff; }
        .nav-btn { flex: 1; padding: 12px; background: #222; color: #fff; border: 1px solid #444; border-radius: 8px; cursor: pointer; font-weight: 600; }
        .active { background: #007bff; border-color: #007bff; font-weight: 800; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 0.9rem; }
        th, td { border-bottom: 1px solid #333; padding: 10px 5px; text-align: left; }
        .clickable { color: #00d4ff; text-decoration: underline; cursor: pointer; font-weight: 700; }
        #add-btn { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); width: 65px; height: 65px; background-color: #ff007f; border-radius: 50%; border: none; color: white; font-size: 35px; z-index: 100; cursor: pointer; box-shadow: 0 0 15px #ff007f; }
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.98); padding: 20px; box-sizing: border-box; overflow-y: auto; z-index: 200; }
        input, select { width: 100%; padding: 12px; background: #1a1a1a; border: 2px solid #555; color: #fff; margin-bottom: 15px; border-radius: 8px; font-weight: 700; font-size: 1.1rem; }
    </style>
</head>
<body>

<div class="container">
    <h1>พอร์ตการลงทุน</h1>
    <div style="display: flex; gap: 5px; margin-bottom: 15px;">
        <button class="nav-btn" id="btn-thai" onclick="showSection('thai')">หุ้นไทย</button>
        <button class="nav-btn" id="btn-foreign" onclick="showSection('foreign')">ตปท</button>
        <button class="nav-btn" id="btn-gold" onclick="showSection('gold')">ทอง</button>
    </div>

    <div class="summary-box">
        <div style="color: #00d4ff;">ยอดซื้อรวมทั้งหมด: <span id="sum-all" style="color: #fff;">0</span></div>
        <div style="margin-top: 10px; border-top: 1px solid #333; padding-top: 10px;">
            <select id="period-select" onchange="renderTable()" style="padding: 5px; font-size: 0.9rem;">
                <option value="all">ทั้งหมด</option>
                <option value="month">สรุปรายเดือนนี้</option>
                <option value="year">สรุปรายปีนี้</option>
            </select>
            <div style="margin-top: 10px;">ยอดในรอบที่เลือก: <span id="sum-period" style="color: #00ff00;">0</span></div>
        </div>
    </div>

    <div id="content-area"></div>
</div>

<button id="add-btn" onclick="openModal()">+</button>

<div id="modal" class="modal">
    <div id="modal-body"></div>
    <button class="nav-btn" onclick="closeModal()" style="width:100%; margin-top:20px; background:#444;">ปิด</button>
</div>

<script>
    let data = JSON.parse(localStorage.getItem('myPortfolio')) || [];

    function showSection(type) {
        localStorage.setItem('activePage', type);
        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('btn-' + type).classList.add('active');
        renderTable();
    }

    function renderTable() {
        const type = localStorage.getItem('activePage') || 'thai';
        const period = document.getElementById('period-select').value;
        const now = new Date();
        
        let filtered = data.filter(i => i.category === type);
        
        // คำนวณสรุป
        let sumAll = filtered.filter(i => i.txType === 'buy').reduce((s, i) => s + Number(i.price), 0);
        document.getElementById('sum-all').innerText = sumAll;

        // กรองตาม period
        let periodFiltered = filtered.filter(i => {
            let itemDate = new Date(i.date);
            if (period === 'month') return itemDate.getMonth() === now.getMonth() && itemDate.getFullYear() === now.getFullYear();
            if (period === 'year') return itemDate.getFullYear() === now.getFullYear();
            return true;
        });

        let sumPeriod = periodFiltered.filter(i => i.txType === 'buy').reduce((s, i) => s + Number(i.price), 0);
        document.getElementById('sum-period').innerText = sumPeriod;

        // แสดงตาราง
        let html = `<table><tr><th>วันที่</th><th>ชื่อ</th><th>เงิน</th><th>จัดการ</th></tr>`;
        periodFiltered.sort((a,b) => new Date(b.date) - new Date(a.date)).forEach(i => {
            html += `<tr><td>${i.date}</td><td class="clickable" onclick="openDetail('${i.name}')">${i.name}</td><td>${i.price}</td>
                <td>
                    <span class="clickable" onclick="editItem('${i.id}')" style="color:#00ff00; margin-right:8px;">[แก้]</span>
                    <span class="clickable" onclick="deleteItem('${i.id}')" style="color:red;">[ลบ]</span>
                </td></tr>`;
        });
        document.getElementById('content-area').innerHTML = html + `</table>`;
    }

    function openDetail(name) {
        let items = data.filter(i => i.name === name);
        let summary = items.reduce((acc, i) => { acc[i.txType] = (acc[i.txType] || 0) + Number(i.price); return acc; }, {});
        let html = `<h2 style="color:#00d4ff;">${name}</h2><p>ซื้อรวม: ${summary.buy || 0}</p><p>ขายรวม: ${summary.sell || 0}</p><p>ปันผล: ${summary.dividend || 0}</p><hr><h3>ประวัติ</h3><ul>`;
        items.sort((a,b) => new Date(b.date) - new Date(a.date)).forEach(i => html += `<li>${i.date} | ${i.txType} | ${i.price}</li>`);
        document.getElementById('modal-body').innerHTML = html + `</ul>`;
        document.getElementById('modal').style.display = 'block';
    }

    function openModal(item = null) {
        let isEdit = !!item;
        document.getElementById('modal-body').innerHTML = `<h3>${isEdit ? 'แก้ไข' : 'เพิ่ม'}</h3>
            <input type="date" id="date" value="${isEdit ? item.date : new Date().toISOString().split('T')[0]}">
            <select id="type-select"><option value="buy" ${isEdit && item.txType === 'buy' ? 'selected' : ''}>ซื้อ</option>
            <option value="sell" ${isEdit && item.txType === 'sell' ? 'selected' : ''}>ขาย</option>
            <option value="dividend" ${isEdit && item.txType === 'dividend' ? 'selected' : ''}>ปันผล</option></select>
            <input type="text" id="name" placeholder="ชื่อ" value="${isEdit ? item.name : ''}">
            <input type="number" id="price" placeholder="จำนวนเงิน" value="${isEdit ? item.price : ''}">
            <button class="nav-btn" onclick="${isEdit ? `updateData('${item.id}')` : 'saveData()'}" style="width:100%; background:#007bff;">บันทึก</button>`;
        document.getElementById('modal').style.display = 'block';
    }

    function saveData() {
        const item = { id: Date.now().toString(), category: localStorage.getItem('activePage'), txType: document.getElementById('type-select').value, date: document.getElementById('date').value, name: document.getElementById('name').value, price: document.getElementById('price').value };
        data.push(item);
        localStorage.setItem('myPortfolio', JSON.stringify(data));
        closeModal();
        renderTable();
    }

    function updateData(id) {
        let index = data.findIndex(i => i.id === id);
        data[index] = { id: id, category: localStorage.getItem('activePage'), txType: document.getElementById('type-select').value, date: document.getElementById('date').value, name: document.getElementById('name').value, price: document.getElementById('price').value };
        localStorage.setItem('myPortfolio', JSON.stringify(data));
        closeModal();
        renderTable();
    }

    function deleteItem(id) {
        if(confirm('ยืนยันการลบ?')) {
            data = data.filter(i => i.id !== id);
            localStorage.setItem('myPortfolio', JSON.stringify(data));
            renderTable();
        }
    }

    function closeModal() { document.getElementById('modal').style.display = 'none'; }
    window.onload = () => showSection(localStorage.getItem('activePage') || 'thai');
</script>
</body>
</html>
